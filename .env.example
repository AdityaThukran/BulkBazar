# BulkBazar — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it's in .gitignore for security.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (public keys — safe to share)
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ─────────────────────────────────────────────────────────────────────────────
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini AI API Key (SERVER-SIDE ONLY — never expose to browser)
# Get a free key from: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_KEY=your-gemini-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Production settings (only needed when deploying)
# ─────────────────────────────────────────────────────────────────────────────
# PORT=5001
# CLIENT_ORIGIN=https://yourdomain.com
# NODE_ENV=production
